# Vercel Environment Variables
# Copy this to Vercel dashboard: Settings > Environment Variables

# Node environment (automatically set by Vercel)
NODE_ENV=production

# Puppeteer configuration for Vercel
PUPPETEER_SKIP_CHROMIUM_DOWNLOAD=false
PUPPETEER_EXECUTABLE_PATH=/usr/bin/google-chrome-stable

# Optional: Custom timeout for domain checking (in milliseconds)
# DOMAIN_CHECK_TIMEOUT=300000
